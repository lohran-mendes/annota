      "Bash(npm install *)",
      "Bash(npm ls *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git checkout -b *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
